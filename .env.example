# LiteLLM Environment Configuration

# Database Configuration (matches docker-compose.yml)
DATABASE_URL=postgresql://llmproxy:dbpassword9090@db:5432/litellm
STORE_MODEL_IN_DB=True

# LiteLLM Master Key (for API authentication)
# Generate a secure key: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-1234

# LiteLLM Salt Key (for encrypting secrets in DB)
# Generate a secure key: openssl rand -hex 32
LITELLM_SALT_KEY=sk-salt-1234

# UI Configuration
# Set to "True" to enable the admin UI
UI_USERNAME=admin
UI_PASSWORD=admin

# Provider API Keys (add your keys here)
# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI
# AZURE_API_KEY=...
# AZURE_API_BASE=https://...
# AZURE_API_VERSION=2024-02-01

# AWS Bedrock
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1

# Google AI / Vertex AI
# GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json
# VERTEX_PROJECT=your-project-id
# VERTEX_LOCATION=us-central1

# Cohere
# COHERE_API_KEY=...

# HuggingFace
# HUGGINGFACE_API_KEY=...

# Logging
# LITELLM_LOG=INFO

# Debugging (set to True for verbose logging)
# DEBUG=False
